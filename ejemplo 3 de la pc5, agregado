#include <iostream>
#include <fstream>
using namespace std;

const double PI = 3.141592653589793;
double miSeno(double x){
    double termino = x;
    double suma = x;

    for(int i = 1; i <= 12; i++){
        termino = -termino * x * x / ((2*i)*(2*i+1));
        suma += termino;
    }

    return suma;
}

double miAbs(double x){
    if(x < 0) return -x;
    return x;
}

